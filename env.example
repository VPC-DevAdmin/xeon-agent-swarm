# ── Single shared text engine ─────────────────────────────────────────────────
# One Mistral-7B instance serves all text roles: orchestrator, workers,
# validator, and reducer. Specialization comes from contract fields (objective,
# scope, success_criteria) injected into each role's prompt.
TEXT_ENGINE_ENDPOINT=http://localhost:8080/v1
TEXT_ENGINE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── vLLM CPU engine tuning (native wheel, Xeon 6 GNR, 64 cores, 1 TB RAM) ────
# Thread binding: partition 64 cores across TP_SIZE workers (16 each).
# Without this, all workers bind to the same cores and throughput collapses ~5×.
VLLM_CPU_OMP_THREADS_BIND=0-15|16-31|32-47|48-63
# KV cache per worker in GB: 16 GB × TP=4 = 64 GB total.
# Default auto can over-allocate; set explicitly to avoid OOM.
VLLM_CPU_KVCACHE_SPACE=16
# OpenMP threads per worker = cores that worker owns
OMP_NUM_THREADS=16
# Tensor parallelism — TP=4 on single-socket Xeon outperforms DP=4 or TP=1
TP_SIZE=4
# Context length (tune per workload; each request KV is capped here)
TEXT_MAX_MODEL_LEN=8192
# Max concurrent sequences in flight per engine
TEXT_MAX_NUM_SEQS=16
# vLLM version pin — leave blank to auto-install latest release at build time
# Set before running: docker compose build vllm-text
VLLM_VERSION=

# ── Concurrency semaphore ──────────────────────────────────────────────────────
# Limits simultaneous requests to the shared text engine.
# Tune to (TP_SIZE × OMP_NUM_THREADS / avg_tokens_per_request).
WORKER_CONCURRENCY=8

# ── Legacy endpoint env vars (kept for backward compatibility) ─────────────────
# These are read by old code that hasn't been updated yet. They map to the same
# single vllm-text engine.
ORCHESTRATOR_ENDPOINT=http://localhost:8080/v1
ORCHESTRATOR_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6479

# ── MCP servers ───────────────────────────────────────────────────────────────
MCP_WEB_SEARCH_URL=http://localhost:9401
MCP_DOC_RETRIEVAL_URL=http://localhost:9402
MCP_CODE_EXEC_URL=http://localhost:9403

# ── Corpus embeddings (TEI service) ───────────────────────────────────────────
TEI_ENDPOINT=http://localhost:8090
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Vision engine (separate — different modality) ─────────────────────────────
# Start with: docker compose --profile vision up -d vllm-vision
# Then set VLM_ENDPOINT and restart backend.
VLM_ENDPOINT=
VLM_MODEL=microsoft/Phi-3.5-vision-instruct

# ── HuggingFace token (for gated models) ─────────────────────────────────────
HF_TOKEN=hf_...

# ── Brave Search API key (optional; MCP web_search falls back to DuckDuckGo) ─
BRAVE_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
