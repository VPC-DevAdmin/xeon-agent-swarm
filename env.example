# ── OPEA Inference endpoints ──────────────────────────────────────────────────
# Orchestrator model (Qwen2.5-7B recommended; needs stronger reasoning)
ORCHESTRATOR_ENDPOINT=http://localhost:8080/v1
ORCHESTRATOR_MODEL=Qwen/Qwen2.5-7B-Instruct

# Worker model — CPU endpoint (Phi-4-mini or Intel/neural-chat-7b-v3-3)
WORKER_CPU_ENDPOINT=http://localhost:8081/v1
WORKER_CPU_MODEL=microsoft/Phi-4-mini-instruct

# Worker model — GPU endpoint (optional; falls back to CPU if not set)
WORKER_GPU_ENDPOINT=http://localhost:8082/v1
WORKER_GPU_MODEL=meta-llama/Llama-3.1-8B-Instruct

# A/B baseline: single large model
SINGLE_MODEL_ENDPOINT=http://localhost:8083/v1
SINGLE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6479

# ── MCP servers ───────────────────────────────────────────────────────────────
MCP_WEB_SEARCH_URL=http://localhost:9401
MCP_DOC_RETRIEVAL_URL=http://localhost:9402
MCP_CODE_EXEC_URL=http://localhost:9403

# ── HuggingFace token (for gated models) ─────────────────────────────────────
HF_TOKEN=hf_...

# ── Brave Search API key (optional; MCP web_search falls back to DuckDuckGo) ─
BRAVE_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
