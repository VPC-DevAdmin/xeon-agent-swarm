# ── OPEA Inference endpoints ──────────────────────────────────────────────────
# Orchestrator + writing + analysis workers (Mistral-7B for prose quality)
ORCHESTRATOR_ENDPOINT=http://localhost:8080/v1
ORCHESTRATOR_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Research, fact-check, summarization workers (Phi-4-mini; smaller = less confabulation)
WORKER_CPU_ENDPOINT=http://localhost:8081/v1
WORKER_CPU_MODEL=microsoft/Phi-4-mini-instruct

# Worker model — GPU endpoint (optional; falls back to CPU if not set)
WORKER_GPU_ENDPOINT=http://localhost:8082/v1
WORKER_GPU_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Code specialist (Qwen2.5-Coder-7B; INT4 quantized via OpenVINO)
CODER_ENDPOINT=http://localhost:8083/v1
CODER_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6479

# ── MCP servers ───────────────────────────────────────────────────────────────
MCP_WEB_SEARCH_URL=http://localhost:9401
MCP_DOC_RETRIEVAL_URL=http://localhost:9402
MCP_CODE_EXEC_URL=http://localhost:9403

# ── Corpus embeddings (TEI service) ───────────────────────────────────────────
TEI_ENDPOINT=http://localhost:8090
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Vision worker (optional; requires --profile vision) ────────────────────────
# Set VLM_ENDPOINT after starting vllm-vision to enable the vision worker.
# Leave empty to fall back to text-only analysis for vision tasks.
VLM_ENDPOINT=
VLM_MODEL=microsoft/Phi-3.5-vision-instruct

# ── HuggingFace token (for gated models) ─────────────────────────────────────
HF_TOKEN=hf_...

# ── Brave Search API key (optional; MCP web_search falls back to DuckDuckGo) ─
BRAVE_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
